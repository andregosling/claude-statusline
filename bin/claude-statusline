#!/usr/bin/env bash
# claude-statusline CLI
# Manage the claude-statusline install: force updates, check status, uninstall.

set -u

REPO_RAW="https://raw.githubusercontent.com/andregosling/claude-statusline/main"
REPO_URL="https://github.com/andregosling/claude-statusline"
CLAUDE_DIR="${HOME}/.claude"
RENDERER="${CLAUDE_DIR}/statusline.sh"
LOADER="${CLAUDE_DIR}/statusline-loader.sh"
SETTINGS="${CLAUDE_DIR}/settings.json"
CACHE_DIR="${CLAUDE_DIR}/cache/claude-statusline"
LAST_CHECK="${CACHE_DIR}/last-check"
UPDATE_LOG="${CACHE_DIR}/update.log"
SELF_PATH="${BASH_SOURCE[0]}"

c_ok="\033[32m"; c_warn="\033[33m"; c_err="\033[31m"; c_dim="\033[2m"; c_b="\033[1m"; c_r="\033[0m"
ok()   { printf "${c_ok}✓${c_r} %s\n" "$*"; }
warn() { printf "${c_warn}!${c_r} %s\n" "$*"; }
err()  { printf "${c_err}✗${c_r} %s\n" "$*" >&2; }
info() { printf "${c_dim}→${c_r} %s\n" "$*"; }

usage() {
  printf "${c_b}claude-statusline${c_r} — manage your Claude Code status line\n\n"
  printf "${c_b}USAGE${c_r}\n  claude-statusline <command>\n\n"
  printf "${c_b}COMMANDS${c_r}\n"
  printf "  update      Force-download the latest statusline.sh from GitHub now\n"
  printf "  status      Show installed files, last update check, and current version\n"
  printf "  version     Print the version of the local statusline.sh\n"
  printf "  uninstall   Remove statusline files and unpatch settings.json\n"
  printf "  help        Show this message\n\n"
  printf "${c_b}REPO${c_r}\n  %s\n" "$REPO_URL"
}

local_version() {
  # Read the "# VERSION: x.y.z" line from a script if present, else "unknown".
  local file="$1"
  [ -f "$file" ] || { printf 'missing'; return; }
  local v
  v="$(grep -m1 '^# VERSION:' "$file" 2>/dev/null | awk '{print $3}')"
  printf '%s' "${v:-unknown}"
}

remote_version() {
  curl -fsSL --max-time 10 "$REPO_RAW/statusline.sh" 2>/dev/null \
    | grep -m1 '^# VERSION:' | awk '{print $3}'
}

cmd_update() {
  command -v curl >/dev/null 2>&1 || { err "curl is required"; exit 1; }
  [ -f "$RENDERER" ] || { err "renderer not found at $RENDERER — run install.sh first"; exit 1; }

  info "fetching latest statusline.sh from $REPO_URL"
  local tmp
  tmp="$(mktemp -t claude-statusline.XXXXXX)" || exit 1
  if ! curl -fsSL --max-time 15 "$REPO_RAW/statusline.sh" -o "$tmp"; then
    err "download failed"
    rm -f "$tmp"
    exit 1
  fi

  if [ ! -s "$tmp" ] || ! head -1 "$tmp" | grep -q '^#!.*\(bash\|sh\)'; then
    err "downloaded file failed sanity check"
    rm -f "$tmp"
    exit 1
  fi

  if cmp -s "$tmp" "$RENDERER"; then
    rm -f "$tmp"
    ok "already on the latest version ($(local_version "$RENDERER"))"
  else
    chmod +x "$tmp"
    mv "$tmp" "$RENDERER"
    mkdir -p "$CACHE_DIR"
    date +%s > "$LAST_CHECK"
    printf '[%s] manual update via CLI\n' "$(date '+%Y-%m-%d %H:%M:%S')" >> "$UPDATE_LOG"
    ok "updated to version $(local_version "$RENDERER")"
  fi

  # Also refresh the loader, since it can change too.
  if [ -f "$LOADER" ]; then
    info "refreshing loader"
    if curl -fsSL --max-time 15 "$REPO_RAW/statusline-loader.sh" -o "$LOADER.new" 2>/dev/null \
       && head -1 "$LOADER.new" | grep -q '^#!.*\(bash\|sh\)'; then
      chmod +x "$LOADER.new"
      mv "$LOADER.new" "$LOADER"
      ok "loader refreshed"
    else
      rm -f "$LOADER.new" 2>/dev/null
      warn "loader refresh skipped"
    fi
  fi
}

cmd_status() {
  printf "${c_b}claude-statusline${c_r}\n\n"

  printf "  renderer:  "
  if [ -f "$RENDERER" ]; then
    printf "%s ${c_dim}(v%s)${c_r}\n" "$RENDERER" "$(local_version "$RENDERER")"
  else
    printf "${c_err}not installed${c_r}\n"
  fi

  printf "  loader:    "
  if [ -f "$LOADER" ]; then
    printf "%s\n" "$LOADER"
  else
    printf "${c_warn}not installed (no auto-update)${c_r}\n"
  fi

  printf "  cli:       %s\n" "${SELF_PATH}"

  printf "  settings:  "
  if [ -f "$SETTINGS" ] && grep -q '"statusLine"' "$SETTINGS" 2>/dev/null; then
    local cmd
    cmd="$(jq -r '.statusLine.command // "?"' "$SETTINGS" 2>/dev/null)"
    printf "configured ${c_dim}(command: %s)${c_r}\n" "$cmd"
  else
    printf "${c_warn}not configured in %s${c_r}\n" "$SETTINGS"
  fi

  printf "\n  last update check:  "
  if [ -f "$LAST_CHECK" ]; then
    local ts age_s now h m
    ts=$(cat "$LAST_CHECK" 2>/dev/null || echo 0)
    now=$(date +%s)
    age_s=$(( now - ts ))
    if   [ "$age_s" -lt 60 ];   then printf "%ds ago\n" "$age_s"
    elif [ "$age_s" -lt 3600 ]; then printf "%dm ago\n" "$((age_s/60))"
    else printf "%dh%02dm ago\n" "$((age_s/3600))" "$(((age_s%3600)/60))"
    fi
  else
    printf "${c_dim}never${c_r}\n"
  fi

  printf "  local version:      ${c_b}%s${c_r}\n" "$(local_version "$RENDERER")"
  printf "  latest on GitHub:   "
  local rv
  rv="$(remote_version)"
  if [ -z "$rv" ]; then
    printf "${c_dim}(network error)${c_r}\n"
  else
    printf "${c_b}%s${c_r}" "$rv"
    if [ "$rv" != "$(local_version "$RENDERER")" ] && [ "$(local_version "$RENDERER")" != "unknown" ]; then
      printf "  ${c_warn}← update available (run: claude-statusline update)${c_r}"
    fi
    printf "\n"
  fi
}

cmd_version() {
  printf "%s\n" "$(local_version "$RENDERER")"
}

cmd_uninstall() {
  printf "${c_warn}!${c_r} This will remove:\n"
  printf "    %s\n    %s\n    %s\n    %s  ${c_dim}(this CLI itself)${c_r}\n" \
    "$RENDERER" "$LOADER" "$CACHE_DIR" "$SELF_PATH"
  printf "  And remove the statusLine section from %s\n" "$SETTINGS"
  printf "\nContinue? [y/N] "
  read -r ans
  case "$ans" in
    y|Y|yes|YES) ;;
    *) info "cancelled"; exit 0 ;;
  esac

  rm -f "$RENDERER" "$LOADER"
  rm -rf "$CACHE_DIR"
  ok "removed scripts and cache"

  if [ -f "$SETTINGS" ] && command -v jq >/dev/null 2>&1; then
    cp "$SETTINGS" "${SETTINGS}.bak.$(date +%s)"
    local tmp
    tmp="$(mktemp)"
    jq 'del(.statusLine)' "$SETTINGS" > "$tmp" && mv "$tmp" "$SETTINGS"
    ok "unpatched $SETTINGS (backup saved)"
  fi

  # Remove the CLI last — once gone, this script can't run anymore.
  if [ -f "$SELF_PATH" ]; then
    rm -f "$SELF_PATH"
    ok "removed CLI: $SELF_PATH"
  fi

  printf "\nReload Claude Code to fully clear the status line.\n"
}

case "${1:-help}" in
  update)    cmd_update ;;
  status)    cmd_status ;;
  version|-v|--version) cmd_version ;;
  uninstall) cmd_uninstall ;;
  help|-h|--help|"") usage ;;
  *) err "unknown command: $1"; echo; usage; exit 2 ;;
esac
